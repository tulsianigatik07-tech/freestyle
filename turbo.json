{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "DISPLAY",
    "HYPRLAND_INSTANCE_SIGNATURE",
    "SWAYSOCK",
    "WAYLAND_DISPLAY",
    "XDG_BACKEND",
    "XDG_CURRENT_DESKTOP",
    "XDG_SESSION_ID",
    "XDG_SESSION_TYPE"
  ],
  "tasks": {
    "compile:native": {
      "inputs": ["native/**"],
      "outputs": ["resources/bin/**"]
    },
    "build": {
      "dependsOn": ["^build", "compile:native"],
      "outputs": ["dist/**", "build/**"]
    },
    "dev": {
      "dependsOn": ["^build", "compile:native"],
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
