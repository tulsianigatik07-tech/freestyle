{
  "name": "@freestyle-voice/workspace",
  "private": true,
  "scripts": {
    "build": "turbo build --filter=!docs",
    "dev": "turbo dev --filter=!docs",
    "dev:docs": "turbo dev --filter=docs",
    "format": "biome check --write .",
    "knip": "knip",
    "test": "turbo test",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "knip": "^6.23.0",
    "nano-staged": "^1.0.2",
    "turbo": "^2.9.14"
  },
  "nano-staged": {
    "*.{ts,tsx,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "packageManager": "pnpm@10.32.1"
}
