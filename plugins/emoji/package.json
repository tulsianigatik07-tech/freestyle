{
  "name": "@freestyle-voice/plugin-emoji",
  "version": "0.1.0",
  "type": "module",
  "description": "Add emojis to your dictation based on conversational tone and style.",
  "license": "MIT",
  "homepage": "https://github.com/freestyle-voice/freestyle/tree/main/plugins/emoji#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freestyle-voice/freestyle.git",
    "directory": "plugins/emoji"
  },
  "keywords": [
    "freestyle",
    "freestyle-plugin",
    "voice",
    "dictation",
    "emoji"
  ],
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "freestyle": {
    "icon": "Smile",
    "contributes": {
      "pages": [
        {
          "id": "emoji-settings",
          "title": "Emoji",
          "entry": "dist/ui/index.html"
        }
      ]
    }
  },
  "scripts": {
    "build": "pkgroll --minify && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui/tsconfig.json",
    "link": "node ../../scripts/link-plugin.mjs",
    "unlink": "node ../../scripts/link-plugin.mjs --unlink"
  },
  "dependencies": {
    "freestyle-voice": "workspace:*"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "hono": "^4.12.22",
    "pkgroll": "^2.27.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.3"
  }
}
