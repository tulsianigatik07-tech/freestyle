{
  "name": "@freestyle-voice/plugin-audio-transcription",
  "version": "0.2.0",
  "type": "module",
  "description": "Transcribe audio files by dropping them into Freestyle.",
  "license": "MIT",
  "homepage": "https://github.com/freestyle-voice/freestyle/tree/main/plugins/audio-transcription#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freestyle-voice/freestyle.git",
    "directory": "plugins/audio-transcription"
  },
  "keywords": [
    "freestyle",
    "freestyle-plugin",
    "voice",
    "dictation",
    "transcription"
  ],
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "freestyle": {
    "icon": "FileMusic",
    "contributes": {
      "pages": [
        {
          "id": "transcribe-files",
          "title": "Transcribe Files",
          "entry": "dist/ui/index.html"
        }
      ]
    }
  },
  "scripts": {
    "build": "pkgroll --minify && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui/tsconfig.json",
    "link": "node ../../scripts/link-plugin.mjs",
    "unlink": "node ../../scripts/link-plugin.mjs --unlink"
  },
  "dependencies": {
    "freestyle-voice": "workspace:*"
  },
  "devDependencies": {
    "pkgroll": "^2.27.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.3"
  }
}
